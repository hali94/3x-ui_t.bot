# ============================================================
# APPLICATION
# ============================================================
APP_NAME=VPN Reseller Platform
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=change-this-to-a-very-long-random-secret-key-min-64-chars
APP_ENCRYPTION_KEY=change-this-to-32-byte-fernet-key==

# ============================================================
# DATABASE
# ============================================================
DATABASE_URL=postgresql+asyncpg://vpnuser:vpnpass@postgres:5432/vpndb
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ============================================================
# REDIS
# ============================================================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ============================================================
# TELEGRAM
# ============================================================
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_ADMIN_IDS=123456789,987654321

# ============================================================
# JWT
# ============================================================
JWT_SECRET_KEY=change-this-to-another-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=200

# ============================================================
# NOTIFICATION THRESHOLDS
# ============================================================
TRAFFIC_WARN_80=true
TRAFFIC_WARN_90=true
TRAFFIC_WARN_100=true
EXPIRY_WARN_DAYS=3

# ============================================================
# WORKER
# ============================================================
WORKER_CONCURRENCY=4
NOTIFICATION_CHECK_INTERVAL_HOURS=6
